# ══════════════════════════════════════════════════════════════
# MemoryOS — Environment Configuration
# Copy this file to .env.local and fill in your values
# ══════════════════════════════════════════════════════════════

# ── LLM Provider ─────────────────────────────────────────────
# Fireworks AI (primary — Llama 3.3 70B Instruct)
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p3-70b-instruct

# Optional: OpenAI fallback
# OPENAI_API_KEY=

# ── 0G Network — Galileo Testnet ─────────────────────────────
# Get testnet OG from https://faucet.0g.ai
WALLET_PRIVATE_KEY=
NEXT_PUBLIC_0G_RPC=https://evmrpc-testnet.0g.ai
NEXT_PUBLIC_0G_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
NEXT_PUBLIC_0G_NETWORK=testnet
NEXT_PUBLIC_CHAIN_ID=16602

# ── Payment Contract (SkillPaymentEscrow) ────────────────────
# Deploy with: npm run payments:deploy:galileo
NEXT_PUBLIC_PAYMENT_CONTRACT_ADDRESS=
PLATFORM_WALLET_ADDRESS=

# ── 0G Compute (Semantic Search) ─────────────────────────────
# Optional: pin a specific embedding provider + model
# ZG_COMPUTE_EMBED_PROVIDER=
# ZG_COMPUTE_EMBED_MODEL=

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
PLATFORM_FEE_PERCENT=5

# ── Security (REQUIRED in production) ────────────────────────
# Platform secret for write endpoint authentication.
# In dev (NODE_ENV=development), endpoints are open if this is unset.
# In production, ALL writes are BLOCKED without this.
MEMORY_SERVICE_SECRET=

# HMAC secret for API key generation and vault encryption.
# Must be set in production — generates deterministic agent API keys.
PLATFORM_HMAC_SECRET=

# ── 0G Manifest Anchor Contract ──────────────────────────────
MANIFEST_ANCHOR_CONTRACT=

# ── 0G Compute Router ────────────────────────────────────────
# Get API key from https://pc.0g.ai
ZG_ROUTER_API_KEY=
ZG_ROUTER_MODEL=deepseek/deepseek-chat-v3-0324

# ── Agent Brain INFTs (ERC-7857) ─────────────────────────────
# Deploy with: npx hardhat run scripts/deploy-inft.js --network galileo
NEXT_PUBLIC_INFT_CONTRACT_ADDRESS=

# ── 0G KV Store ──────────────────────────────────────────────
# Optional: custom stream ID for KV operations
# ZG_KV_STREAM_ID=
